# Backend Port
PORT=3001

# Database
DATABASE_URL="postgresql://user:password@host/db_name"

# Discord Credentials
DISCORD_APPLICATION_ID="your_discord_application_id"
DISCORD_PUBLIC_KEY="your_discord_public_key"
DISCORD_BOT_TOKEN="your_discord_bot_token"

# Optional: Set for faster command updates during dev
DISCORD_GUILD_ID="your_discord_test_server_id"

# Notification Webhook (Slack or Discord)
NOTIFICATION_WEBHOOK_URL="your_webhook_url"

# Admin Dashboard Auth
JWT_SECRET="your_secure_random_jwt_secret"

# AI Integration
GROQ_API_KEY="your_groq_api_key"

# Frontend Integration
FRONTEND_URL="http://localhost:5173"
